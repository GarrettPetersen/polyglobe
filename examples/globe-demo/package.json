{
  "name": "globe-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:buildings": "vite --open /building-viewer.html",
    "dev:rivers": "vite --open /river-hex-viewer.html",
    "dev:river-bank": "vite --open /river-bank-hex-viewer.html",
    "build": "vite build",
    "preview": "vite preview",
    "download-data": "node scripts/download-data.mjs",
    "build-koppen": "node scripts/build-koppen.mjs",
    "build-elevation": "node scripts/build-elevation.mjs",
    "build-tavg-monthly": "node scripts/build-tavg-monthly.mjs",
    "build-tavg-worldclim": "node scripts/build-tavg-worldclim.mjs",
    "analyze-tavg-frozen-land": "npx tsx scripts/analyze-tavg-monthly-land-freeze.ts",
    "report-jan1-temp": "npx tsx scripts/report-jan1-temp-model.ts",
    "build-mountains": "node scripts/build-mountains.mjs",
    "build-land-raster-png": "node scripts/build-land-raster-png.mjs",
    "setup-data": "npm run download-data && npm run build-koppen && npm run build-mountains && npm run build-land-raster-png && npm run build-elevation && npm run build-tavg-monthly",
    "build-earth-globe-cache": "npx tsx scripts/build-earth-globe-cache.ts",
    "build-earth-globe-cache-all": "npx tsx scripts/build-earth-globe-cache.ts 7",
    "merge-urbanization-reba": "node scripts/merge-urbanization-reba.mjs",
    "bake-discrete-weather": "npx tsx scripts/bake-discrete-weather-from-globe-cache.ts",
    "list-assets": "node scripts/list-assets.mjs",
    "rename-assets": "node scripts/rename-assets.mjs",
    "perf:capture-long-cloud-tick": "env PERF_EXTRA_QUERY='dayLengthSec=15&cloudTick=120' PERF_FRAME_REPORTS=6 node scripts/capture-perf-console.mjs",
    "perf:capture-low-latency-preset": "env PERF_EXTRA_QUERY='dayLengthSec=15&lowLatencyClouds=1' PERF_FRAME_REPORTS=6 node scripts/capture-perf-console.mjs"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "earcut": "^3.0.2",
    "jszip": "^3.10.1",
    "polygon-clipping": "^0.15.7",
    "three": "^0.170.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@types/earcut": "^3.0.0",
    "canvas": "^3.2.1",
    "geotiff": "^2.1.3",
    "playwright": "^1.58.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
}
